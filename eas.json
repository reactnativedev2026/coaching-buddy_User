{
    "cli": {
        "version": ">= 16.3.1",
        "appVersionSource": "remote"
    },
    "build": {
        "development": {
            "developmentClient": true,
            "distribution": "internal",
            "env": {
                "EXPO_PUBLIC_SERVER_URL": "http://192.168.1.242:5000/api",
                "EXPO_PUBLIC_AUTH_TOKEN_STORAGE_KEY": "COACHING_BUDDY_AUTH_TOKEN",
                "EXPO_PUBLIC_SAVED_STORAGE_KEY": "COACHING_BUDDY_SAVED",
                "EXPO_PUBLIC_RECENT_SEARCHES_STORAGE_KEY": "COACHING_BUDDY_RECENT_SEARCHES",
                "EXPO_PUBLIC_RECENT_SEARCHES_SIZE": "5"
            }
        },
        "preview": {
            "distribution": "internal",
            "env": {
                "EXPO_PUBLIC_SERVER_URL": "https://coachingbuddy.co.in/api",
                "EXPO_PUBLIC_AUTH_TOKEN_STORAGE_KEY": "COACHING_BUDDY_AUTH_TOKEN",
                "EXPO_PUBLIC_SAVED_STORAGE_KEY": "COACHING_BUDDY_SAVED",
                "EXPO_PUBLIC_RECENT_SEARCHES_STORAGE_KEY": "COACHING_BUDDY_RECENT_SEARCHES",
                "EXPO_PUBLIC_RECENT_SEARCHES_SIZE": "5"
            }
        },
        "production": {
            "autoIncrement": true,
            "env": {
                "EXPO_PUBLIC_SERVER_URL": "https://coachingbuddy.co.in/api",
                "EXPO_PUBLIC_AUTH_TOKEN_STORAGE_KEY": "COACHING_BUDDY_AUTH_TOKEN",
                "EXPO_PUBLIC_SAVED_STORAGE_KEY": "COACHING_BUDDY_SAVED",
                "EXPO_PUBLIC_RECENT_SEARCHES_STORAGE_KEY": "COACHING_BUDDY_RECENT_SEARCHES",
                "EXPO_PUBLIC_RECENT_SEARCHES_SIZE": "5"
            }
        }
    },
    "submit": {
        "production": {}
    }
}
